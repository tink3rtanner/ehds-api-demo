# copy to .env for prod; run.sh sets sane dev defaults already.
EHDS_BASE_URL=https://ehds-demo.example.org
EHDS_ISSUER=https://ehds-demo.example.org
EHDS_DATA_DIR=/var/lib/ehds-api/data
EHDS_CLIENT_REGISTRY=/etc/ehds-api/clients.json
EHDS_JWKS_PATH=/var/lib/ehds-api/keys
EHDS_VALIDATOR_JAR=/var/lib/ehds-api/validator_cli.jar
ENV=prod
PORT=8000
EHDS_RATE_LIMIT_PER_MIN=120
EHDS_BODY_MAX_BYTES=5242880
